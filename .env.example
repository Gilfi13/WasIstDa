# Kopieren nach .env oder .env.local im Projektroot, dann Dev-Server neu starten.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Küchen-Assistent (OpenAI) – ohne diesen Key schlägt die App auf direkten OpenAI-Zugriff zurück,
# falls die Edge Function recipe-suggestions nicht erreichbar ist.
VITE_OPENAI_API_KEY=

# Optional: eigenes Backend POST { "lines": string[] } → { "dishes": [...] }
# VITE_RECIPE_AI_PROXY_URL=
